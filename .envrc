#!/usr/bin/env bash
dotenv_if_exists .env
dotenv_if_exists .api_key

if has nix; then
  # devenv.sh dev shell (replaces the old `use flake .`). nix-direnv users get a
  # cached env on cd; stock direnv pays the eval each time.
  if ! has use_devenv; then
    eval "$(devenv direnvrc)"
  fi
  use devenv

  if [ -f ../.envrc ]; then
      source_env ../.envrc
  fi
fi
